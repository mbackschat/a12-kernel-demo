@@ -178,7 +178,11 @@ tasks.matching {
 }
 
 // tests are shared across all mmdmjsons subprojects, in the :test-mmdmjsons subproject
-evaluationDependsOn(":test-mmdmjsons")
+// OSS-build patch (B1): the eager evaluationDependsOn force-evaluated :test-mmdmjsons mid-apply, whose own
+// evaluationDependsOn(":mmdmjsons:…mm_field-1-a12") then pre-evaluated that synthetic subproject before the
+// root subprojects{} loop applied maven-publish to it → "Cannot run afterEvaluate when already evaluated".
+// The :test-* projects sort after the :mm* projects, so natural config order evaluates them last; the lazy
+// task dependsOn below needs no eager evaluation. (Was: evaluationDependsOn(":test-mmdmjsons"))
 tasks.matching { it.name.equals("test") }.configureEach {
     dependsOn(":test-mmdmjsons:test")
 }
